{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://weltgewebe.org/schemas/domain/node.schema.json",
  "title": "Node",
  "description": "A node in the Weltgewebe graph.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "info": {
      "type": ["string", "null"],
      "description": "Freitext-Info (Markdown erlaubt)."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Short summary. A longer 'description' field is reserved for future use."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "location": {
      "type": "object",
      "properties": {
        "lat": {
          "type": "number"
        },
        "lon": {
          "type": "number"
        }
      },
      "required": ["lat", "lon"],
      "additionalProperties": false
    }
  },
  "required": ["id", "kind", "title", "created_at", "updated_at"],
  "additionalProperties": false
}
