{
  "$id": "https://weltgewebe.org/schemas/agent/run-result.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "artifacts": {
      "additionalProperties": false,
      "properties": {
        "handoff": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "enum": [
                "handoff.json"
              ]
            },
            "sha256": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            }
          },
          "required": [
            "path",
            "sha256"
          ],
          "type": "object"
        },
        "run_result": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "enum": [
                "run-result.json"
              ]
            }
          },
          "required": [
            "path"
          ],
          "type": "object"
        },
        "task": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "enum": [
                "task.yml"
              ]
            },
            "sha256": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            }
          },
          "required": [
            "path",
            "sha256"
          ],
          "type": "object"
        },
        "validation": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "enum": [
                "validation.json"
              ]
            },
            "sha256": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            }
          },
          "required": [
            "path",
            "sha256"
          ],
          "type": "object"
        }
      },
      "required": [
        "task",
        "handoff",
        "validation",
        "run_result"
      ],
      "type": "object"
    },
    "completed_at": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$",
      "type": "string"
    },
    "evidence_accounting": {
      "type": "object"
    },
    "execution_plan": {
      "type": "object"
    },
    "findings": {
      "type": "array"
    },
    "handoff": {
      "type": "object"
    },
    "mode": {
      "enum": [
        "dry_run"
      ]
    },
    "outcome": {
      "enum": [
        "incomplete"
      ]
    },
    "repository_state": {
      "additionalProperties": false,
      "properties": {
        "git_visible_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "source_revision": {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        }
      },
      "required": [
        "source_revision",
        "git_visible_sha256"
      ],
      "type": "object"
    },
    "repository_state_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "repository_unchanged": {
      "enum": [
        true
      ]
    },
    "residual_gaps": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "run_id": {
      "pattern": "^RUN-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{12}$",
      "type": "string"
    },
    "schema_version": {
      "enum": [
        "1.0"
      ]
    },
    "source_revision": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "stages": {
      "minItems": 1,
      "type": "array"
    },
    "started_at": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$",
      "type": "string"
    },
    "status": {
      "enum": [
        "planned"
      ]
    },
    "task_contract_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "task_file": {
      "minLength": 1,
      "type": "string"
    },
    "task_id": {
      "pattern": "^[A-Z]+(-[A-Z]+)*-[0-9]{3}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "mode",
    "status",
    "task_file",
    "task_id",
    "task_contract_sha256",
    "source_revision",
    "stages",
    "findings",
    "execution_plan",
    "evidence_accounting",
    "handoff",
    "repository_unchanged",
    "repository_state_sha256",
    "artifacts",
    "residual_gaps",
    "outcome",
    "started_at",
    "completed_at",
    "repository_state"
  ],
  "title": "Agent Run Evidence Result",
  "type": "object"
}
