{
  "$id": "https://weltgewebe.org/schemas/agent/validation.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Run Evidence Validation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "created_at",
    "task_id",
    "task_contract_sha256",
    "source_revision",
    "repository_state_sha256",
    "status",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "enum": [
        "1.0"
      ]
    },
    "run_id": {
      "type": "string",
      "pattern": "^RUN-[0-9]{4}(?:(?:0[13578]|1[02])(?:0[1-9]|[12][0-9]|3[01])|(?:0[469]|11)(?:0[1-9]|[12][0-9]|30)|02(?:0[1-9]|1[0-9]|2[0-9]))T(?:[01][0-9]|2[0-3])[0-5][0-9][0-5][0-9]Z-[0-9a-f]{12}$"
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12][0-9]|3[01])|(?:0[469]|11)-(?:0[1-9]|[12][0-9]|30)|02-(?:0[1-9]|1[0-9]|2[0-9]))T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{6}Z$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Z]+(-[A-Z]+)*-[0-9]{3}$"
    },
    "task_contract_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "source_revision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "repository_state_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "status": {
      "enum": [
        "passed"
      ]
    },
    "checks": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "status"
          ],
          "properties": {
            "name": {
              "enum": [
                "task_schema"
              ]
            },
            "status": {
              "enum": [
                "passed"
              ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "status"
          ],
          "properties": {
            "name": {
              "enum": [
                "claim_registry"
              ]
            },
            "status": {
              "enum": [
                "passed"
              ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "status"
          ],
          "properties": {
            "name": {
              "enum": [
                "non_ideal_guard"
              ]
            },
            "status": {
              "enum": [
                "passed"
              ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "status"
          ],
          "properties": {
            "name": {
              "enum": [
                "handoff_contract"
              ]
            },
            "status": {
              "enum": [
                "passed"
              ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "status"
          ],
          "properties": {
            "name": {
              "enum": [
                "repository_unchanged"
              ]
            },
            "status": {
              "enum": [
                "passed"
              ]
            }
          }
        }
      ],
      "additionalItems": false
    }
  }
}
