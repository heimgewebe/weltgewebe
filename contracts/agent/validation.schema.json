{
  "$id": "https://weltgewebe.org/schemas/agent/validation.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "checks": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "name": {
            "pattern": "^[a-z][a-z0-9_]*$",
            "type": "string"
          },
          "status": {
            "enum": [
              "passed"
            ]
          }
        },
        "required": [
          "name",
          "status"
        ],
        "type": "object"
      },
      "minItems": 5,
      "type": "array",
      "uniqueItems": true
    },
    "created_at": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$",
      "type": "string"
    },
    "repository_state_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "run_id": {
      "pattern": "^RUN-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{12}$",
      "type": "string"
    },
    "schema_version": {
      "enum": [
        "1.0"
      ]
    },
    "source_revision": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "status": {
      "enum": [
        "passed"
      ]
    },
    "task_contract_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "task_id": {
      "pattern": "^[A-Z]+(-[A-Z]+)*-[0-9]{3}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "created_at",
    "task_id",
    "task_contract_sha256",
    "source_revision",
    "repository_state_sha256",
    "status",
    "checks"
  ],
  "title": "Agent Run Evidence Validation",
  "type": "object"
}
