{
  "$id": "https://weltgewebe.org/schemas/agent/validation.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Run Evidence Validation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "created_at",
    "task_id",
    "task_contract_sha256",
    "source_revision",
    "repository_state_sha256",
    "status",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "enum": [
        "1.0"
      ]
    },
    "run_id": {
      "type": "string",
      "pattern": "^RUN-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{12}$"
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Z]+(-[A-Z]+)*-[0-9]{3}$"
    },
    "task_contract_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "source_revision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "repository_state_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "status": {
      "enum": [
        "passed"
      ]
    },
    "checks": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "enum": [
              "task_schema",
              "claim_registry",
              "non_ideal_guard",
              "handoff_contract",
              "repository_unchanged"
            ]
          },
          "status": {
            "enum": [
              "passed"
            ]
          }
        }
      }
    }
  }
}
