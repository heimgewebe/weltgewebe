{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://weltgewebe.org/schemas/wgx/metrics.schema.json",
  "title": "WGX Metrics Snapshot",
  "description": "Schema for the metrics snapshot produced by wgx-metrics-snapshot.sh.",
  "type": "object",
  "properties": {
    "ts": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp of the snapshot."
    },
    "host": {
      "type": "string",
      "minLength": 1,
      "description": "Hostname of the machine that produced the snapshot."
    },
    "updates": {
      "type": "object",
      "properties": {
        "os": {
          "type": "integer",
          "minimum": 0
        },
        "pkg": {
          "type": "integer",
          "minimum": 0
        },
        "flatpak": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["os", "pkg", "flatpak"],
      "additionalProperties": false
    },
    "backup": {
      "type": "object",
      "properties": {
        "last_ok": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "ISO 8601 date (YYYY-MM-DD) of the last successful backup."
        },
        "age_days": {
          "type": "integer",
          "minimum": 0,
          "description": "Age of the last successful backup in days."
        }
      },
      "required": ["last_ok", "age_days"],
      "additionalProperties": false
    },
    "drift": {
      "type": "object",
      "properties": {
        "templates": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of drifted templates."
        }
      },
      "required": ["templates"],
      "additionalProperties": false
    }
  },
  "required": ["ts", "host", "updates", "backup", "drift"],
  "additionalProperties": false
}
