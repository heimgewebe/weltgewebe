# --- DB ---
POSTGRES_USER=welt
POSTGRES_PASSWORD=change_me
POSTGRES_DB=weltgewebe
DATABASE_URL=postgres://welt:change_me@db:5432/weltgewebe

# --- Web upstream (Cloudflare Pages oder Vercel) ---
WEB_UPSTREAM_HOST=leitstand.pages.dev
WEB_UPSTREAM_URL=https://leitstand.pages.dev

# --- Logging ---
RUST_LOG=info

# --- API ---
API_BIND=0.0.0.0:8080

# --- Seeding ---
# Demo sample data (development only). Set to true to seed demo data on startup if missing.
# GEWEBE_SEED_DEMO=true
#
# Real initial account bootstrap. Idempotent (skips if metadata file already exists).
# For a real deployment set GEWEBE_SEED_REAL=true and keep GEWEBE_SEED_DEMO=false.
# Also set the required bootstrap fields below.
# GEWEBE_SEED_REAL=true
#
# Required when GEWEBE_SEED_REAL=true:
# ACCOUNT_TITLE=Alice
# PUBLIC_LAT=53.5503
# PUBLIC_LON=9.9932
#
# Optional bootstrap fields:
# ACCOUNT_ID=             # auto-generated if empty
# ACCOUNT_SUMMARY=
# ACCOUNT_ROLE=weber
# ACCOUNT_TYPE=garnrolle
# ACCOUNT_TAGS=real
# ACCOUNT_EMAIL=
